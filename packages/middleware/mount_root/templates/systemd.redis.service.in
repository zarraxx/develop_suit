[Unit]
Description=Redis single-node service (@SERVICE_NAME@)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@SERVICE_USER@
EnvironmentFile=@ENV_FILE@
ExecStartPre=/bin/sh -lc 'mkdir -p "${REDIS_DATA_DIR}" "${REDIS_RUN_DIR}"'
ExecStart=/bin/sh -lc 'exec "${MIDDLEWARE_PACKAGE_ROOT}/bin/redis-server" "${REDIS_CONFIG_FILE}"'
ExecStop=/bin/sh -lc 'if [ -n "${REDIS_PASSWORD}" ]; then exec "${MIDDLEWARE_PACKAGE_ROOT}/bin/redis-cli" -h 127.0.0.1 -p 6379 -a "${REDIS_PASSWORD}" shutdown; else exec "${MIDDLEWARE_PACKAGE_ROOT}/bin/redis-cli" -h 127.0.0.1 -p 6379 shutdown; fi'
TimeoutStartSec=60
TimeoutStopSec=60
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
