[Unit]
Description=MinIO single-node service (@SERVICE_NAME@)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=@SERVICE_USER@
EnvironmentFile=@ENV_FILE@
ExecStartPre=/bin/sh -lc 'mkdir -p "${MINIO_DATA_DIR}"'
ExecStart=/bin/sh -lc 'exec "${MIDDLEWARE_PACKAGE_ROOT}/bin/minio" server "${MINIO_DATA_DIR}" --address ":9000" --console-address ":9001"'
TimeoutStartSec=60
TimeoutStopSec=60
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
