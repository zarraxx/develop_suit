diff --git a/build/toolchain/win/toolchain.gni b/build/toolchain/win/toolchain.gni
index a2a7108..fecde67 100644
--- a/build/toolchain/win/toolchain.gni
+++ b/build/toolchain/win/toolchain.gni
@@ -6,12 +6,18 @@ import("//build/config/clang/clang.gni")
 import("//build/config/compiler/compiler.gni")
 import("//build/config/rust.gni")
 import("//build/config/sanitizers/sanitizers.gni")
-import("//build/config/win/visual_studio_version.gni")
+if (!is_mingw) {
+  import("//build/config/win/visual_studio_version.gni")
+}
 import("//build/toolchain/cc_wrapper.gni")
 import("//build/toolchain/goma.gni")
 import("//build/toolchain/rbe.gni")
 import("//build/toolchain/toolchain.gni")
-import("//build/toolchain/win/win_toolchain_data.gni")
+if (is_mingw) {
+  import("//build/toolchain/gcc_toolchain.gni")
+} else {
+  import("//build/toolchain/win/win_toolchain_data.gni")
+}
 
 assert(is_win, "Should only be running on Windows")
 
@@ -729,3 +735,37 @@ template("win_toolchains") {
     }
   }
 }
+
+
+template("mingw_toolchain") {
+  gcc_toolchain("mingw_" + target_name) {
+    forward_variables_from(invoker, "*")
+    if (toolchain_arch == "x64") {
+      mingw_triple = "x86_64-w64-windows-gnu"
+    } else if (toolchain_arch == "x86") {
+      mingw_triple = "i686-w64-windows-gnu"
+    } else {
+      assert(false, "unsupported MinGW toolchain arch: $toolchain_arch")
+    }
+
+    cc = "$clang_base_path/bin/${mingw_triple}-clang-gcc"
+    cxx = "$clang_base_path/bin/${mingw_triple}-clang-g++"
+    ld = cxx
+    ar = "$clang_base_path/bin/llvm-ar"
+    nm = "$clang_base_path/bin/llvm-nm"
+    readelf = "$clang_base_path/bin/llvm-readobj"
+    strip = "$clang_base_path/bin/llvm-strip"
+    executable_extension = ".exe"
+    shlib_extension = ".dll"
+    enable_linker_map = false
+    extra_cflags = "-DWIN32 -D_WINDOWS"
+    extra_ldflags = "-Wl,--out-implib={{output_dir}}/{{target_output_name}}.dll.a"
+
+    toolchain_args = {
+      current_os = "win"
+      current_cpu = toolchain_arch
+      is_clang = true
+      develop_suit_mingw = true
+    }
+  }
+}
