diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -38,4 +38,27 @@ include(CheckPythonModuleExists)
 include(GenerateBuiltinsList)
 
+set(V8_HOST_BYTECODE_BUILTINS_LIST_GENERATOR "" CACHE FILEPATH "Path to host bytecode_builtins_list_generator")
+set(V8_HOST_TORQUE "" CACHE FILEPATH "Path to host torque executable")
+set(V8_HOST_MKSNAPSHOT "" CACHE FILEPATH "Path to host mksnapshot executable")
+
+set(V8_BYTECODE_BUILTINS_LIST_GENERATOR_TOOL "bytecode_builtins_list_generator")
+set(V8_BYTECODE_BUILTINS_LIST_GENERATOR_DEP "bytecode_builtins_list_generator")
+if(V8_HOST_BYTECODE_BUILTINS_LIST_GENERATOR)
+  set(V8_BYTECODE_BUILTINS_LIST_GENERATOR_TOOL "${V8_HOST_BYTECODE_BUILTINS_LIST_GENERATOR}")
