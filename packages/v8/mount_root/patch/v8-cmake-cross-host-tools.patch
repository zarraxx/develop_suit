   COMMAND
     ${CMAKE_COMMAND} -P ${PROJECT_BINARY_DIR}/touch_torque_outputs.cmake
   DEPENDS
-    torque
+    ${V8_TORQUE_DEP}
     ${torque_dirs}
     ${torque_files_abs}
   OUTPUT
     ${torque-outputs}
diff --git a/cmake/GenerateBuiltinsList.cmake b/cmake/GenerateBuiltinsList.cmake
--- a/cmake/GenerateBuiltinsList.cmake
+++ b/cmake/GenerateBuiltinsList.cmake
@@ -7,8 +7,8 @@ function(v8_generate_builtins_list target-dir)
