+  set(V8_TORQUE_DEP "${V8_HOST_TORQUE}")
+endif()
+set(V8_MKSNAPSHOT_TOOL "mksnapshot")
+set(V8_MKSNAPSHOT_DEP "mksnapshot")
+if(V8_HOST_MKSNAPSHOT)
+  set(V8_MKSNAPSHOT_TOOL "${V8_HOST_MKSNAPSHOT}")
+  set(V8_MKSNAPSHOT_DEP "${V8_HOST_MKSNAPSHOT}")
+endif()
+
 check_python_module_exists(PYTHON_HAVE_MARKUPSAFE markupsafe)
 
 if (NOT CMAKE_CXX_STANDARD)
@@ -628,18 +651,18 @@ target_link_libraries(v8_snapshot
 # Note: allow passing in v8_random_seed
 add_custom_command(
   COMMAND
-    mksnapshot
+    ${V8_MKSNAPSHOT_TOOL}
     --embedded_src ${PROJECT_BINARY_DIR}/embedded.S
     --startup_src ${PROJECT_BINARY_DIR}/snapshot.cc
     $<${is-arm64}:--target_arch=arm64>
     $<${is-x64}:--target_arch=x64>
     $<${is-ppc}:--target_arch=ppc>
     $<${is-ppc64}:--target_arch=ppc64>
     $<$<PLATFORM_ID:Darwin>:--target_os=mac>
     $<$<PLATFORM_ID:Linux>:--target_os=linux>
     $<$<PLATFORM_ID:Windows>:--target_os=win>
     --turbo_instruction_scheduling
   DEPENDS
-    mksnapshot
+    ${V8_MKSNAPSHOT_DEP}
   OUTPUT
     ${PROJECT_BINARY_DIR}/embedded.S
     ${PROJECT_BINARY_DIR}/snapshot.cc
@@ -1008,15 +1031,15 @@ file(WRITE "${PROJECT_BINARY_DIR}/touch_torque_outputs.cmake"
 
 add_custom_command(
   COMMAND
-    torque
+    ${V8_TORQUE_TOOL}
