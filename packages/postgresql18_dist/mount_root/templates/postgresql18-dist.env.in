# PostgreSQL 18 distribution runtime environment
#
# Copy this file to a writable location, adjust the values for your deployment,
# and reference it from the matching systemd unit with:
#   EnvironmentFile=/path/to/postgresql18-dist.env

POSTGRESQL18_DIST_PREFIX=@SDK_PREFIX@
POSTGRESQL18_DIST_DATADIR=/var/lib/postgresql18-dist
POSTGRESQL18_DIST_PORT=5432
POSTGRESQL18_DIST_LISTEN_ADDRESSES=127.0.0.1
POSTGRESQL18_DIST_EXTRA_POSTGRES_ARGS=

# initdb defaults for ICU-based cluster creation:
#   "${POSTGRESQL18_DIST_PREFIX}/bin/initdb" \
#     --locale-provider="${POSTGRESQL18_DIST_INITDB_LOCALE_PROVIDER}" \
#     --icu-locale="${POSTGRESQL18_DIST_INITDB_ICU_LOCALE}" \
#     --encoding="${POSTGRESQL18_DIST_INITDB_ENCODING}" \
#     --auth-local="${POSTGRESQL18_DIST_INITDB_AUTH_LOCAL}" \
#     --auth-host="${POSTGRESQL18_DIST_INITDB_AUTH_HOST}" \
#     -D "${POSTGRESQL18_DIST_DATADIR}"
POSTGRESQL18_DIST_INITDB_LOCALE_PROVIDER=icu
POSTGRESQL18_DIST_INITDB_ICU_LOCALE=en-US
POSTGRESQL18_DIST_INITDB_ENCODING=UTF8
POSTGRESQL18_DIST_INITDB_AUTH_LOCAL=trust
POSTGRESQL18_DIST_INITDB_AUTH_HOST=scram-sha-256

PATH=@SDK_PREFIX@/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
LD_LIBRARY_PATH=@SDK_PREFIX@/lib:@SDK_PREFIX@/lib64
PYTHONHOME=@SDK_PREFIX@
PYTHONPATH=@POSTGRESQL18_DIST_PYTHONPATH@
PERL5LIB=@POSTGRESQL18_DIST_PERL5LIB@
TCL_LIBRARY=@POSTGRESQL18_DIST_TCL_LIBRARY@
PROJ_DATA=@SDK_PREFIX@/share/proj
GDAL_DATA=@SDK_PREFIX@/share/gdal
ODBCSYSINI=@SDK_PREFIX@/etc
ODBCINI=@SDK_PREFIX@/etc/odbc.ini
FREETDSCONF=@SDK_PREFIX@/etc/freetds.conf
MARIADB_PLUGIN_DIR=@SDK_PREFIX@/lib/mariadb/plugin
MYSQL_PLUGIN_DIR=@SDK_PREFIX@/lib/mariadb/plugin

# Optional vendor or site-local overrides for FDW client libraries:
# ORACLE_HOME=/opt/oracle/instantclient
# TNS_ADMIN=/opt/oracle/network/admin
# DB2_HOME=/opt/db2/clidriver
# DB2INSTANCE=db2inst1
