#!/usr/bin/env bash
set -euo pipefail

default_service_name="postgresql18"
service_name="${1:-$default_service_name}"

die() {
  echo "error: $*" >&2
  exit 1
}

[[ "$service_name" =~ ^[A-Za-z0-9_.@-]+$ ]] || die "invalid service name: ${service_name}"
command -v systemctl >/dev/null 2>&1 || die "systemctl is required"

if [[ "$(id -u)" -ne 0 ]]; then
  command -v sudo >/dev/null 2>&1 || die "root privileges or sudo are required to uninstall a system service"
  exec sudo "$0" "$service_name"
fi

service_file="/etc/systemd/system/${service_name}.service"
env_file="/etc/default/${service_name}"

if systemctl list-unit-files --type=service --no-legend 2>/dev/null | awk '{print $1}' | grep -qx "${service_name}.service"; then
  systemctl disable --now "$service_name" >/dev/null 2>&1 || true
elif systemctl list-units --type=service --all --no-legend 2>/dev/null | awk '{print $1}' | grep -qx "${service_name}.service"; then
  systemctl stop "$service_name" >/dev/null 2>&1 || true
fi

rm -f "$service_file" "$env_file"
systemctl daemon-reload
systemctl reset-failed "$service_name" >/dev/null 2>&1 || true

echo "Uninstalled systemd service: ${service_name}"
echo "Data directory and service user were left unchanged."
