@echo off
setlocal EnableExtensions EnableDelayedExpansion

if "%~1"=="" (
  set "SERVICE_NAME=postgresql18"
) else (
  set "SERVICE_NAME=%~1"
)

echo(!SERVICE_NAME!| findstr /R /C:"^[A-Za-z0-9_.@-][A-Za-z0-9_.@-]*$" >nul
if errorlevel 1 (
  echo error: invalid service name: !SERVICE_NAME!
  exit /b 1
)

sc query "%SERVICE_NAME%" >nul 2>nul
if errorlevel 1 (
  echo Service does not exist: %SERVICE_NAME%
  exit /b 0
)

sc stop "%SERVICE_NAME%" >nul 2>nul
sc delete "%SERVICE_NAME%"
if errorlevel 1 exit /b 1

echo Uninstalled Windows service: %SERVICE_NAME%
echo Data directory was left unchanged.
