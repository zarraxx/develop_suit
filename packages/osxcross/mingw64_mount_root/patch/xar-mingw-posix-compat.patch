diff --git a/xar/lib/xar_mingw_compat.h b/xar/lib/xar_mingw_compat.h
new file mode 100644
--- /dev/null
+++ b/xar/lib/xar_mingw_compat.h
@@ -0,0 +1,53 @@
+#ifndef XAR_MINGW_COMPAT_H
+#define XAR_MINGW_COMPAT_H
+
+#ifdef _WIN32
+
+#include <stddef.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <time.h>
+
+#ifndef lstat
+#define lstat stat
+#endif
+
+static inline struct tm *
+xar_mingw_gmtime_r(const time_t *timer, struct tm *result)
+{
+	return gmtime_s(result, timer) == 0 ? result : NULL;
+}
+
+#ifndef gmtime_r
+#define gmtime_r xar_mingw_gmtime_r
+#endif
+
+static inline char *
+xar_mingw_strsep(char **stringp, const char *delim)
+{
+	char *begin;
+	char *end;
+
+	if (stringp == NULL || *stringp == NULL)
+		return NULL;
+
+	begin = *stringp;
+	end = begin + strcspn(begin, delim);
+
+	if (*end != '\0') {
+		*end = '\0';
+		*stringp = end + 1;
+	} else {
+		*stringp = NULL;
+	}
+
+	return begin;
+}
+
+#ifndef strsep
+#define strsep xar_mingw_strsep
+#endif
+
+#endif /* _WIN32 */
+
+#endif /* XAR_MINGW_COMPAT_H */
